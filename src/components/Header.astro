---
import { Menu } from '@lucide/astro';

const base = import.meta.env.BASE_URL;
const withBase = (path = '') => `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;

const nav = [
  { href: withBase('/announcements/'), label: 'Announcements' },
  { href: withBase('/tcrl-icra/'), label: 'TCRL@ICRA', highlight: true },
  { href: withBase('/resources/'), label: 'Resources' },
  { href: withBase('/people/'), label: 'People' },
  { href: withBase('/join/'), label: 'Join' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/')} aria-label="IEEE RAS TC on Robot Learning home">
      <span class="brand-lockup" aria-hidden="true">
        <span class="brand-crop brand-symbol">
          <img src={withBase('/images/TCRL-Logo-squared.png')} alt="" />
        </span>
        <span class="brand-crop brand-wordmark">
          <img src={withBase('/images/TCRL-Logo-squared.png')} alt="" />
        </span>
      </span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {nav.map((item) => <a href={item.href} class:list={[{ highlight: item.highlight }]}>{item.label}</a>)}
    </nav>
    <details class="mobile-nav">
      <summary aria-label="Open navigation">
        <Menu size={20} />
      </summary>
      <div class="mobile-menu">
        {nav.map((item) => <a href={item.href} class:list={[{ highlight: item.highlight }]}>{item.label}</a>)}
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(16, 20, 24, 0.1);
    background: rgba(251, 252, 253, 0.86);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: grid;
    min-height: 72px;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    /* Tweak these crop values to adjust the two navbar logo windows. */
    --brand-gap: 0.62rem;
    --symbol-width: 125px;
    --symbol-height: 45px;
    --symbol-image-width: 125px;
    --symbol-x: 0px;
    --symbol-y: 0px;
    --wordmark-width:100px;
    --wordmark-height: 30px;
    --wordmark-image-width: 150px;
    --wordmark-x: -10px;
    --wordmark-y: -58px;
    --brand-full-width: calc(var(--symbol-width) + var(--wordmark-width) + var(--brand-gap));
    --brand-scale: min(1, calc((100vw - 112px) / var(--brand-full-width)));
    display: inline-flex;
    align-items: center;
    width: calc(var(--brand-full-width) * var(--brand-scale));
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    gap: var(--brand-gap);
    transform: scale(var(--brand-scale));
    transform-origin: left center;
  }

  .brand-crop {
    position: relative;
    display: block;
    flex: 0 0 auto;
    overflow: hidden;
  }

  .brand-crop img {
    position: absolute;
    top: 0;
    left: 0;
    max-width: none;
    height: auto;
  }

  .brand-symbol {
    width: var(--symbol-width);
    height: var(--symbol-height);
  }

  .brand-symbol img {
    width: var(--symbol-image-width);
    transform: translate(var(--symbol-x), var(--symbol-y));
  }

  .brand-wordmark {
    width: var(--wordmark-width);
    height: var(--wordmark-height);
  }

  .brand-wordmark img {
    width: var(--wordmark-image-width);
    transform: translate(var(--wordmark-x), var(--wordmark-y));
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    color: #26323c;
    font-size: 0.91rem;
    font-weight: 760;
  }

  .nav a {
    border-bottom: 2px solid transparent;
    padding-block: 0.4rem;
  }

  .nav a:hover {
    border-color: var(--accent);
  }

  .nav a.highlight,
  .mobile-menu a.highlight {
    border-color: rgba(217, 94, 26, 0.22);
    border-radius: 999px;
    background: rgba(217, 94, 26, 0.12);
    color: #8c3d0f;
    padding-inline: 0.78rem;
  }

  .nav a.highlight:hover,
  .mobile-menu a.highlight:hover {
    border-color: rgba(217, 94, 26, 0.5);
    background: rgba(217, 94, 26, 0.18);
  }

  .mobile-nav {
    position: relative;
    display: none;
  }

  .mobile-nav summary {
    display: none;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: white;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 0.65rem);
    display: grid;
    width: min(260px, calc(100vw - 28px));
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 0.55rem;
    box-shadow: 0 18px 44px rgba(16, 20, 24, 0.18);
  }

  .mobile-menu a {
    border-radius: 6px;
    color: #22303a;
    font-weight: 800;
    padding: 0.8rem;
  }

  .mobile-menu a:hover {
    background: var(--panel);
  }

  @media (max-width: 860px) {
    .header-inner {
      grid-template-columns: 1fr auto;
    }

    .nav {
      display: none;
    }

    .mobile-nav {
      display: block;
    }

    .mobile-nav summary {
      display: grid;
    }
  }
</style>
